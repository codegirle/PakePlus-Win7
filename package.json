{
    "name": "pakeplus-win7",
    "version": "1.0.0",
    "description": "跨平台桌面应用，支持 Windows 7",
    "main": "dist/main.js",
    "scripts": {
        "build:ts": "tsc",
        "start": "tsc && electron .",
        "build": "tsc && electron-builder",
        "build:win": "tsc && electron-builder --win",
        "build:win32": "tsc && electron-builder --win --ia32",
        "build:win64": "tsc && electron-builder --win --x64",
        "build:mac": "tsc && electron-builder --mac",
        "build:linux": "tsc && electron-builder --linux",
        "icon:icns": "node scripts/createIcon.cjs -icon app-icon.png -padding 1 -format icns",
        "icon:ico": "node scripts/createIcon.cjs -icon app-icon.png",
        "worker:pp": "node scripts/ppworker.cjs"
    },
    "keywords": [
        "electron",
        "desktop",
        "cross-platform"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "electron": "^22.3.27",
        "electron-builder": "^24.9.1",
        "typescript": "^5.7.0",
        "@types/node": "^22.10.0",
        "@types/electron": "^1.6.12"
    },
    "build": {
        "appId": "com.pakeplus.win7",
        "productName": "PakePlus-Win7",
        "directories": {
            "output": "dist"
        },
        "files": [
            "dist/**",
            "package.json"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "ia32",
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "ia32",
                        "x64"
                    ]
                }
            ],
            "icon": "icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "icon.icns"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}
