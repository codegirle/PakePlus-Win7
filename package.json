{
    "name": "PakePlusWin7",
    "version": "0.0.4",
    "description": "Package HTML/Web/Vue/React Projects into Desktop/Mobile Apps in minutes",
    "main": "src-electron/main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder",
        "build:win": "electron-builder --win",
        "build:win32": "electron-builder --win --ia32",
        "build:win64": "electron-builder --win --x64",
        "build:mac": "electron-builder --mac",
        "build:mac-arm64": "electron-builder --mac --arm64",
        "build:linux": "electron-builder --linux",
        "worker:pp": "node scripts/ppworker.cjs",
        "icon": "tauri icon icon.png -o icons"
    },
    "keywords": [
        "electron",
        "desktop",
        "cross-platform"
    ],
    "author": {
        "name": "xiaoshen",
        "email": "1024xiaoshen@gmail.com"
    },
    "license": "MIT",
    "devDependencies": {
        "electron": "^22.3.27",
        "electron-builder": "^24.9.1",
        "png-to-ico": "^3.0.1",
        "png2icons": "^2.0.1",
        "@tauri-apps/cli": "^2",
        "sharp": "^0.34.5"
    },
    "build": {
        "appId": "com.pakeplus.win7",
        "productName": "PakePlusWin7",
        "asar": true,
        "directories": {
            "output": "dist"
        },
        "files": [
            "src-electron/**",
            "src/**",
            "package.json"
        ],
        "win": {
            "compression": "maximum",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "ia32",
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "ia32",
                        "x64"
                    ]
                }
            ],
            "icon": "icons/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "icons/icon.icns"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "icons/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}
